{
  "name": "find-my-new-job-api",
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "start": "node --env-file=.env dist/index.js",
    "lint": "biome lint src",
    "format": "biome check --write src",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^25.5.0",
    "@types/uuid": "^10.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tsup": "^8.5.1",
    "tsx": "^4.19.2",
    "typescript": "^6.0.2"
  },
  "lint-staged": {
    "src/**/*.ts": "biome check --error-on-warnings"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^9.4.0",
    "@fastify/redis": "^7.2.0",
    "@fastify/swagger": "^9.7.0",
    "@scalar/fastify-api-reference": "^1.49.5",
    "apify-client": "^2.22.3",
    "fastify": "^5.8.4",
    "ioredis": "^5.10.1",
    "uuid": "^13.0.0"
  }
}
